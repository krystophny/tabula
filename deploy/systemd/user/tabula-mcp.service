[Unit]
Description=Tabula Local MCP Daemon
After=network.target

[Service]
Type=simple
WorkingDirectory=%h/code/tabula
Environment=HOME=%h
Environment=SHELL=/usr/bin/bash
Environment=PYTHONUNBUFFERED=1
ExecStart=/usr/bin/bash -lc 'source ~/.bashrc >/dev/null 2>&1 || true; exec %h/code/tabula/.venv/bin/python -m tabula.cli serve --project-dir %h/code/tabula --host 127.0.0.1 --port 9420'
Restart=on-failure
RestartSec=2

[Install]
WantedBy=default.target
