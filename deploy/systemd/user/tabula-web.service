[Unit]
Description=Tabula Web UI
After=network.target tabula-mcp.service tabula-ptyd.service
Wants=tabula-mcp.service tabula-ptyd.service

[Service]
Type=simple
WorkingDirectory=%h/code/tabula
PassEnvironment=DISPLAY WAYLAND_DISPLAY XAUTHORITY XDG_RUNTIME_DIR DBUS_SESSION_BUS_ADDRESS
Environment=HOME=%h
Environment=SHELL=/usr/bin/bash
ExecStart=/usr/bin/bash -lc 'source ~/.bashrc >/dev/null 2>&1 || true; cd %h/code/tabula; exec /usr/bin/env go run ./cmd/tabula web --project-dir %h/code/tabula --data-dir %h/.local/share/tabula-web --host 0.0.0.0 --port 8420 --local-mcp-url http://127.0.0.1:9420/mcp --ptyd-url http://127.0.0.1:9333 --dev-runtime'
Restart=on-failure
RestartSec=2
TimeoutStopSec=5

[Install]
WantedBy=default.target
